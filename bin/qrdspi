#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_DIR="$(CDPATH= cd -P -- "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
readonly RUNNER_ROOT="$(CDPATH= cd -P -- "${SCRIPT_DIR}/.." && pwd -P)"
readonly PROMPTS_DIR="${RUNNER_ROOT}/codex/qrdspi/prompts"

dry_run=false
run_once=false

die() {
    echo "error: $*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage:
  qrdspi [--dry-run] [--once] start <task prompt>
  qrdspi [--dry-run] [--once] resume [<artifact-root-or-artifact-file-or-topic>]
  qrdspi delete
  qrdspi [--dry-run] [--once] <jira-issue-key-or-browse-url>

Options:
  --dry-run  Print resolved workflow state and the intended Codex launch command.
  --once     Launch at most one stage invocation, then stop.
  -h, --help Show this help text.
EOF
}

abspath_dir() {
    local target_dir="$1"
    (
        cd -- "$target_dir"
        pwd
    )
}

artifacts_home_dir() {
    printf '%s/.codex/artifacts\n' "$HOME"
}

slugify() {
    local value="$1"
    local slug

    slug="$(printf '%s' "$value" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"

    [ -n "$slug" ] || die "unable to derive a topic slug from: $value"
    printf '%s\n' "$slug"
}

normalize_jira_reference() {
    local value="$1"

    if [[ "$value" =~ ^([A-Z][A-Z0-9]+-[0-9]+)$ ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    if [[ "$value" =~ /browse/([A-Z][A-Z0-9]+-[0-9]+)([/?#].*)?$ ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

normalize_start_prompt() {
    local value="$1"
    local jira_reference

    jira_reference="$(normalize_jira_reference "$value" || true)"
    if [ -n "$jira_reference" ]; then
        printf '%s\n' "$jira_reference"
        return
    fi

    printf '%s\n' "$value"
}

list_artifact_roots() {
    local artifacts_home="$1"

    [ -d "$artifacts_home" ] || return 0
    find "$artifacts_home" -mindepth 2 -maxdepth 2 -type d | LC_ALL=C sort
}

prompt_artifact_root_selection() {
    local root_count="$1"
    local action_label="$2"
    local choice

    while true; do
        printf '\nSelect artifact root to %s [1-%s] or q to cancel:\n' "$action_label" "$root_count" >&2
        printf '> ' >&2

        if ! IFS= read -r choice; then
            return 1
        fi

        case "$choice" in
            q|Q|quit|Quit)
                return 1
                ;;
            ''|*[!0-9]*)
                printf 'Enter a number from 1 to %s, or q.\n' "$root_count" >&2
                ;;
            *)
                if [ "$choice" -ge 1 ] && [ "$choice" -le "$root_count" ]; then
                    printf '%s\n' "$choice"
                    return 0
                fi

                printf 'Enter a number from 1 to %s, or q.\n' "$root_count" >&2
                ;;
        esac
    done
}

confirm_artifact_root_deletion() {
    local artifact_root="$1"
    local choice

    printf 'Delete artifact root %s? [y/N]: ' "$artifact_root" >&2

    if ! IFS= read -r choice; then
        return 1
    fi

    case "$choice" in
        y|Y|yes|YES|Yes)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

normalize_artifact_root_for_deletion() {
    local artifacts_home="$1"
    local artifact_root="$2"
    local normalized_home
    local normalized_root

    [ -d "$artifact_root" ] || die "artifact root does not exist: $artifact_root"

    normalized_home="$(abspath_dir "$artifacts_home")"
    normalized_root="$(abspath_dir "$artifact_root")"

    [[ "$normalized_root" == "$normalized_home"/* ]] || die "refusing to delete outside ${normalized_home}: ${normalized_root}"
    [ "$(dirname "$(dirname "$normalized_root")")" = "$normalized_home" ] || die "refusing to delete non-root artifact directory: ${normalized_root}"

    printf '%s\n' "$normalized_root"
}

delete_artifact_root_command() {
    local artifacts_home
    local selection_index
    local selected_root
    local i
    local artifact_roots=()

    artifacts_home="$(artifacts_home_dir)"

    while IFS= read -r artifact_root; do
        [ -n "$artifact_root" ] || continue
        artifact_roots+=("$(abspath_dir "$artifact_root")")
    done < <(list_artifact_roots "$artifacts_home")

    if [ "${#artifact_roots[@]}" -eq 0 ]; then
        echo "No artifact roots found under ${artifacts_home}"
        return 0
    fi

    echo "Artifact roots under ${artifacts_home}:"
    for ((i = 0; i < ${#artifact_roots[@]}; i++)); do
        printf '%d. %s\n' "$((i + 1))" "${artifact_roots[$i]}"
    done

    selection_index="$(prompt_artifact_root_selection "${#artifact_roots[@]}" "delete")" || {
        echo "Deletion cancelled."
        return 0
    }

    selected_root="${artifact_roots[$((selection_index - 1))]}"
    selected_root="$(normalize_artifact_root_for_deletion "$artifacts_home" "$selected_root")"

    if ! confirm_artifact_root_deletion "$selected_root"; then
        echo "Deletion cancelled."
        return 0
    fi

    rm -rf -- "$selected_root"
    echo "Deleted artifact root: ${selected_root}"
}

prompt_resume_target_selection() {
    local artifacts_home
    local selection_index
    local selected_root
    local i
    local artifact_roots=()

    artifacts_home="$(artifacts_home_dir)"

    while IFS= read -r artifact_root; do
        [ -n "$artifact_root" ] || continue
        artifact_roots+=("$(abspath_dir "$artifact_root")")
    done < <(list_artifact_roots "$artifacts_home")

    if [ "${#artifact_roots[@]}" -eq 0 ]; then
        echo "No artifact roots found under ${artifacts_home}"
        return 1
    fi

    echo "Artifact roots under ${artifacts_home}:"
    for ((i = 0; i < ${#artifact_roots[@]}; i++)); do
        printf '%d. %s\n' "$((i + 1))" "${artifact_roots[$i]}"
    done

    selection_index="$(prompt_artifact_root_selection "${#artifact_roots[@]}" "resume")" || {
        echo "Resume cancelled."
        return 1
    }

    selected_root="${artifact_roots[$((selection_index - 1))]}"
    resolve_resume_target "$selected_root"
}

artifact_path() {
    local stage_name="$1"

    printf '%s/%s--%s.md\n' "$ARTIFACT_ROOT" "$stage_name" "$TOPIC_SLUG"
}

artifact_exists() {
    local stage_name="$1"

    [ -f "$(artifact_path "$stage_name")" ]
}

artifact_status() {
    local artifact_file="$1"

    [ -f "$artifact_file" ] || return 1

    awk '
        BEGIN { in_frontmatter = 0 }
        /^---$/ {
            if (in_frontmatter == 0) {
                in_frontmatter = 1
                next
            }
            exit
        }
        in_frontmatter == 1 && /^Status:/ {
            sub(/^Status:[[:space:]]*/, "", $0)
            print tolower($0)
            exit
        }
    ' "$artifact_file"
}

artifact_title() {
    local artifact_file="$1"

    [ -f "$artifact_file" ] || return 1

    awk '
        BEGIN { in_frontmatter = 0 }
        /^---$/ {
            if (in_frontmatter == 0) {
                in_frontmatter = 1
                next
            }
            exit
        }
        in_frontmatter == 1 && /^Title:/ {
            sub(/^Title:[[:space:]]*/, "", $0)
            gsub(/^"/, "", $0)
            gsub(/"$/, "", $0)
            print
            exit
        }
    ' "$artifact_file"
}

stage_approved() {
    local artifact_file
    local status

    artifact_file="$(artifact_path "$1")"
    status="$(artifact_status "$artifact_file" || true)"
    [ "$status" = "approved" ]
}

stage_prompt_path() {
    case "$1" in
        question) printf '%s/question.md\n' "$PROMPTS_DIR" ;;
        research) printf '%s/research.md\n' "$PROMPTS_DIR" ;;
        design) printf '%s/design.md\n' "$PROMPTS_DIR" ;;
        structure) printf '%s/structure.md\n' "$PROMPTS_DIR" ;;
        plan) printf '%s/plan.md\n' "$PROMPTS_DIR" ;;
        implement-plan) printf '%s/implement-plan.md\n' "$PROMPTS_DIR" ;;
        *) die "unknown stage: $1" ;;
    esac
}

stage_skill_name() {
    case "$1" in
        question) printf 'question-stage\n' ;;
        research) printf 'research-codebase\n' ;;
        design) printf 'design-discussion\n' ;;
        structure) printf 'structure-outline\n' ;;
        plan) printf 'plan-implementation\n' ;;
        implement-plan) printf 'implement-plan\n' ;;
        *) die "unknown stage: $1" ;;
    esac
}

stage_input_artifact() {
    case "$1" in
        research) artifact_path question ;;
        design) artifact_path research ;;
        structure) artifact_path design ;;
        plan) artifact_path structure ;;
        implement-plan) artifact_path plan ;;
        question) printf '\n' ;;
        *) die "unknown stage: $1" ;;
    esac
}

stage_skill_invocation() {
    local stage_name="$1"
    local skill_name
    local input_artifact

    skill_name="$(stage_skill_name "$stage_name")"
    input_artifact="$(stage_input_artifact "$stage_name")"

    if [ "$stage_name" = "question" ]; then
        printf '$%s %q\n' "$skill_name" "$TASK_PROMPT"
        return
    fi

    printf '$%s %q\n' "$skill_name" "$input_artifact"
}

build_runner_contract_block() {
    local stage_name="$1"
    local input_artifact

    cat <<EOF
## QRDSPI Runner Contract

\`\`\`text
SkillInvocation: $(stage_skill_invocation "$stage_name")
ProjectRoot: ${PROJECT_ROOT}
ProjectKey: ${PROJECT_KEY}
EOF

    if [ -n "${ARTIFACT_ROOT:-}" ]; then
        printf 'ArtifactRoot: %s\n' "$ARTIFACT_ROOT"
    fi

    if [ "$stage_name" = "question" ]; then
        printf 'TaskPrompt: %s\n' "$TASK_PROMPT"
    else
        input_artifact="$(stage_input_artifact "$stage_name")"
        printf 'InputArtifact: %s\n' "$input_artifact"
    fi

    cat <<EOF
\`\`\`

EOF

    if [ "$stage_name" = "question" ]; then
        printf -- '- Task prompt: `%s`\n' "$TASK_PROMPT"
    else
        printf -- '- Input artifact: `%s`\n' "$input_artifact"
    fi

    cat <<EOF
- Use \`artifact-management\` to locate, create, or update the correct QRDSPI artifacts for this workflow.
- Let the skill discover sibling artifacts from the same artifact root when it needs more context.
- Stop when human input or approval is still needed, or when the stage artifact remains unresolved.
- Do not advance to the next stage.
EOF
}

build_review_variables_block() {
    local review_action="$1"

    cat <<EOF
## Runner Variable Values

\`\`\`text
ProjectRoot: ${PROJECT_ROOT}
ProjectKey: ${PROJECT_KEY}
ArtifactRoot: ${ARTIFACT_ROOT}
TopicSlug: ${TOPIC_SLUG}
TaskPrompt: ${TASK_PROMPT}
PlanArtifact: $(artifact_path plan)
ReviewAction: ${review_action}
ResumeTarget: ${RESUME_TARGET}
\`\`\`
EOF
}

build_prompt() {
    local stage_name="$1"
    local prompt_file
    prompt_file="$(stage_prompt_path "$stage_name")"
    cat "$prompt_file"
    printf '\n\n'
    build_runner_contract_block "$stage_name"
}

review_prompt_path() {
    case "$1" in
        approve) printf '%s/review-approve-commit.md\n' "$PROMPTS_DIR" ;;
        request-changes) printf '%s/review-request-changes.md\n' "$PROMPTS_DIR" ;;
        *) die "unknown review action: $1" ;;
    esac
}

build_review_prompt() {
    local review_action="$1"

    local prompt_file
    prompt_file="$(review_prompt_path "$review_action")"
    cat "$prompt_file"
    printf '\n\n'
    build_review_variables_block "$review_action"
}

find_existing_artifact_root() {
    local topic_slug="$1"
    local candidate
    local candidates=(
        "${HOME}/.codex/artifacts/${PROJECT_KEY}/${topic_slug}"
    )

    for candidate in "${candidates[@]}"; do
        if [ -d "$candidate" ]; then
            printf '%s\n' "$(abspath_dir "$candidate")"
            return 0
        fi
    done

    return 1
}

resolve_resume_target() {
    local target="$1"
    local base_name

    target="$(normalize_start_prompt "$target")"
    RESUME_TARGET="$target"

    if [ -d "$target" ]; then
        ARTIFACT_ROOT="$(abspath_dir "$target")"
        TOPIC_SLUG="$(basename "$ARTIFACT_ROOT")"
        return
    fi

    if [ -f "$target" ]; then
        ARTIFACT_ROOT="$(abspath_dir "$(dirname "$target")")"
        base_name="$(basename "$target")"
        if [[ "$base_name" == *--*.md ]]; then
            TOPIC_SLUG="${base_name#*--}"
            TOPIC_SLUG="${TOPIC_SLUG%.md}"
        else
            TOPIC_SLUG="$(basename "$ARTIFACT_ROOT")"
        fi
        return
    fi

    TOPIC_SLUG="$(slugify "$target")"
    ARTIFACT_ROOT="$(find_existing_artifact_root "$TOPIC_SLUG" || true)"
    [ -n "$ARTIFACT_ROOT" ] || die "could not find an existing workflow for resume target: $target"
}

resolve_start_target() {
    TASK_PROMPT="$(normalize_start_prompt "$TASK_PROMPT")"
    RESUME_TARGET=""
    ARTIFACT_ROOT=""
    TOPIC_SLUG=""
}

resolve_task_prompt_for_resume() {
    local question_artifact
    local title

    question_artifact="$(artifact_path question)"
    title="$(artifact_title "$question_artifact" || true)"

    if [ -n "$title" ]; then
        TASK_PROMPT="$title"
    else
        TASK_PROMPT="$TOPIC_SLUG"
    fi
}

git_in_repo() {
    git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

git_head_commit() {
    git_in_repo || return 1
    git -C "$PROJECT_ROOT" rev-parse --verify HEAD 2>/dev/null
}

git_has_worktree_changes() {
    git_in_repo || return 1
    [ -n "$(git -C "$PROJECT_ROOT" status --short --untracked-files=all 2>/dev/null)" ]
}

print_review_diff() {
    echo
    echo "Post-phase review for ${PROJECT_ROOT}"
    echo
    echo "git status --short --untracked-files=all"
    git -C "$PROJECT_ROOT" status --short --untracked-files=all
    echo
    echo "git diff --no-ext-diff --submodule=diff"
    git -C "$PROJECT_ROOT" --no-pager diff --no-ext-diff --submodule=diff
}

prompt_review_action() {
    local choice

    while true; do
        printf '\nReview action:\n' >&2
        printf '  1. Approve and launch Codex to commit\n' >&2
        printf '  2. Request changes in Codex\n' >&2
        printf '> ' >&2

        if ! IFS= read -r choice; then
            return 1
        fi

        case "$choice" in
            1|approve|Approve)
                printf 'approve\n'
                return 0
                ;;
            2|request|Request|changes|Changes|request-changes)
                printf 'request-changes\n'
                return 0
                ;;
            *)
                echo "Enter 1 or 2." >&2
                ;;
        esac
    done
}

phase_status_table() {
    local plan_artifact="$1"

    [ -f "$plan_artifact" ] || return 1

    awk '
        function emit_phase() {
            if (phase_heading != "") {
                print phase_heading "\t" phase_status
            }
        }

        /^## Phase [0-9]+:/ {
            emit_phase()
            phase_heading = $0
            phase_status = "not-started"
            in_execution_status = 0
            next
        }

        /^### Execution Status$/ {
            in_execution_status = 1
            next
        }

        /^### / {
            in_execution_status = 0
            next
        }

        in_execution_status == 1 && /^Status:/ {
            status_line = $0
            sub(/^Status:[[:space:]]*/, "", status_line)
            phase_status = tolower(status_line)
            next
        }

        END {
            emit_phase()
        }
    ' "$plan_artifact"
}

count_completed_phases() {
    local plan_artifact="$1"

    [ -f "$plan_artifact" ] || return 1
    phase_status_table "$plan_artifact" | awk -F '\t' '$2 == "completed" { count++ } END { print count + 0 }'
}

determine_execution_stage() {
    local plan_artifact
    local saw_phase=false
    local phase_heading
    local phase_status

    plan_artifact="$(artifact_path plan)"
    [ -f "$plan_artifact" ] || die "approved plan artifact is missing: $plan_artifact"

    while IFS=$'\t' read -r phase_heading phase_status; do
        [ -n "$phase_heading" ] || continue
        saw_phase=true

        case "$phase_status" in
            completed)
                continue
                ;;
            not-started)
                NEXT_STAGE="implement-plan"
                STOP_REASON=""
                return
                ;;
            blocked|waiting-for-manual-verification)
                NEXT_STAGE=""
                STOP_REASON="${phase_heading} is ${phase_status}; resolve that execution checkpoint before continuing"
                return
                ;;
            *)
                NEXT_STAGE=""
                STOP_REASON="${phase_heading} has unsupported execution status '${phase_status}'; update the plan artifact before continuing"
                return
                ;;
        esac
    done < <(phase_status_table "$plan_artifact")

    if ! "$saw_phase"; then
        NEXT_STAGE=""
        STOP_REASON="approved plan does not define any executable phases"
        return
    fi

    NEXT_STAGE=""
    STOP_REASON="all approved plan phases are completed"
}

determine_next_stage() {
    NEXT_STAGE=""
    STOP_REASON=""

    if [ "$MODE" = "start" ]; then
        NEXT_STAGE="question"
        return
    fi

    if artifact_exists plan && stage_approved plan; then
        determine_execution_stage
        return
    fi

    if artifact_exists plan; then
        NEXT_STAGE="plan"
        return
    fi

    if artifact_exists structure; then
        if stage_approved structure; then
            NEXT_STAGE="plan"
        else
            NEXT_STAGE="structure"
        fi
        return
    fi

    if artifact_exists design; then
        if stage_approved design; then
            NEXT_STAGE="structure"
        else
            NEXT_STAGE="design"
        fi
        return
    fi

    if artifact_exists research; then
        NEXT_STAGE="design"
        return
    fi

    if artifact_exists question; then
        NEXT_STAGE="research"
        return
    fi

    if [ -n "${ARTIFACT_ROOT:-}" ]; then
        NEXT_STAGE="question"
        STOP_REASON="no QRDSPI artifacts found under ${ARTIFACT_ROOT}"
        return
    fi
}

print_dry_run() {
    local stage_name="$1"
    local prompt_file

    prompt_file="$(stage_prompt_path "$stage_name")"

    cat <<EOF
Mode: ${MODE}
ProjectRoot: ${PROJECT_ROOT}
ProjectKey: ${PROJECT_KEY}
SelectedStage: ${stage_name}
PromptTemplate: ${prompt_file}
SkillInvocation: $(stage_skill_invocation "$stage_name")
LaunchCommand: codex --cd ${PROJECT_ROOT} '<contents of ${prompt_file} plus appended QRDSPI runner contract>'
EOF

    if [ -n "${ARTIFACT_ROOT:-}" ]; then
        printf 'ArtifactRoot: %s\n' "$ARTIFACT_ROOT"
    fi

    if [ -n "${TOPIC_SLUG:-}" ]; then
        printf 'TopicSlug: %s\n' "$TOPIC_SLUG"
    fi

    printf '\n'
    build_runner_contract_block "$stage_name"
}

launch_codex_prompt() {
    local launch_label="$1"
    local prompt="$2"

    command -v codex >/dev/null 2>&1 || die "codex CLI is not available in PATH"
    echo "Launching ${launch_label} from ${PROJECT_ROOT}"
    codex --cd "$PROJECT_ROOT" "$prompt"
}

launch_stage() {
    local stage_name="$1"
    local prompt

    prompt="$(build_prompt "$stage_name")"
    launch_codex_prompt "$stage_name" "$prompt"
}

run_post_phase_review() {
    local review_action
    local prompt
    local head_before
    local head_after

    if ! git_has_worktree_changes; then
        echo "Skipping post-phase review: working tree is clean"
        return
    fi

    while true; do
        print_review_diff
        review_action="$(prompt_review_action)" || die "post-phase review aborted"
        prompt="$(build_review_prompt "$review_action")"

        case "$review_action" in
            approve)
                head_before="$(git_head_commit || true)"
                launch_codex_prompt "post-phase approval" "$prompt"
                head_after="$(git_head_commit || true)"

                if [ "$head_before" != "$head_after" ]; then
                    return
                fi

                echo "Post-phase approval did not create a commit; review again."
                ;;
            request-changes)
                launch_codex_prompt "post-phase change request" "$prompt"

                if ! git_has_worktree_changes; then
                    echo "Post-phase review complete: working tree is clean"
                    return
                fi
                ;;
        esac
    done
}

while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run)
            dry_run=true
            shift
            ;;
        --once)
            run_once=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

[ $# -gt 0 ] || {
    usage >&2
    exit 1
}

case "$1" in
    start|resume|delete)
        MODE="$1"
        shift
        ;;
    *)
        if [ $# -eq 1 ] && normalize_jira_reference "$1" >/dev/null 2>&1; then
            MODE="start"
        else
            usage >&2
            die "unknown argument: $1"
        fi
        ;;
esac

PROJECT_ROOT="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)"
PROJECT_KEY="$(basename "$PROJECT_ROOT")"

case "$MODE" in
    start)
        [ $# -ge 1 ] || die "start requires a task prompt"
        TASK_PROMPT="$*"
        resolve_start_target
        ;;
    resume)
        if [ $# -eq 0 ]; then
            prompt_resume_target_selection || exit 0
        elif [ $# -eq 1 ]; then
            resolve_resume_target "$1"
        else
            die "resume accepts at most one artifact root, artifact file, or topic"
        fi
        resolve_task_prompt_for_resume
        ;;
    delete)
        [ $# -eq 0 ] || die "delete does not accept additional arguments"
        "$dry_run" && die "delete does not support --dry-run"
        "$run_once" && die "delete does not support --once"
        delete_artifact_root_command
        exit 0
        ;;
    *)
        die "unsupported mode: $MODE"
        ;;
esac

while true; do
    local_stage=""
    completed_phases_before=0
    completed_phases_after=0

    determine_next_stage

    if [ -z "$NEXT_STAGE" ]; then
        echo "Stopped: ${STOP_REASON}"
        exit 0
    fi

    if "$dry_run"; then
        print_dry_run "$NEXT_STAGE"
        exit 0
    fi

    local_stage="$NEXT_STAGE"

    if [ "$local_stage" = "implement-plan" ]; then
        completed_phases_before="$(count_completed_phases "$(artifact_path plan)" || printf '0')"
    fi

    launch_stage "$local_stage"

    if [ "$local_stage" = "implement-plan" ]; then
        completed_phases_after="$(count_completed_phases "$(artifact_path plan)" || printf '0')"

        if [ "$completed_phases_after" -gt "$completed_phases_before" ]; then
            run_post_phase_review
        fi
    fi

    if "$run_once"; then
        echo "Stopped: --once requested after ${local_stage}"
        exit 0
    fi

    determine_next_stage

    if [ -z "$NEXT_STAGE" ]; then
        echo "Stopped: ${STOP_REASON}"
        exit 0
    fi

    if [ "$NEXT_STAGE" = "$local_stage" ]; then
        echo "Stopped: ${local_stage} still requires human input, approval, or artifact updates before the runner can continue"
        exit 0
    fi
done
