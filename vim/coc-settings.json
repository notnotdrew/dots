{
  "diagnostic-languageserver.filetypes": {
    "prisma": "prisma",
    "css": "stylelint",
    "scss": "stylelint",
    "sass": "stylelint",
    "less": "stylelint"
  },
  "diagnostic-languageserver.formatFiletypes": {
    "css": "stylelint",
    "scss": "stylelint",
    "sass": "stylelint",
    "less": "stylelint"
  },
  "diagnostic-languageserver.mergeConfig": true,
  "diagnostic-languageserver.debug": true,
  "diagnostic-languageserver.trace.server": "verbose",
  "coc.preferences.formatOnSave": true,
  "prettier.requireConfig": true,
  "eslint.autoFixOnSave": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "diagnostic.enableMessage": "always",
  "diagnostic.messageTarget": "float",
  "diagnostic.checkCurrentLine": true,
  "diagnostic-languageserver.linters": {
    "prisma": {
      "command": "npx",
      "args": ["--yes", "prisma-lint", "-o", "json", "%filepath"],
      "rootPatterns": ["package.json", ".git"],
      "sourceName": "prisma-lint",
      "isStdout": true,
      "isStderr": true,
      "parseJson": {
        "errorsRoot": "violations",
        "line": "location.startLine",
        "column": "location.startColumn",
        "message": "${message} [${ruleName}]",
        "code": "ruleName",
        "sourceName": "fileName",
        "sourceNameFilter": true
      },
      "securities": {
        "error": "error",
        "warning": "warning",
        "info": "info"
      }
    },
    "stylelint": {
      "command": "stylelint",
      "args": [
        "--stdin",
        "--stdin-filename",
        "%filepath",
        "--formatter",
        "json"
      ],
      "rootPatterns": [
        "package.json",
        ".stylelintrc",
        ".stylelintrc.json",
        ".stylelintrc.yaml",
        ".stylelintrc.yml",
        ".stylelintrc.js",
        ".stylelintrc.cjs",
        ".stylelintrc.mjs",
        "stylelint.config.js",
        "stylelint.config.cjs",
        "stylelint.config.mjs",
        ".git"
      ],
      "sourceName": "stylelint",
      "parseJson": {
        "errorsRoot": "[0].warnings",
        "line": "line",
        "column": "column",
        "message": "${text}",
        "security": "severity"
      },
      "securities": {
        "error": "error",
        "warning": "warning"
      }
    }
  },
  "diagnostic-languageserver.formatters": {
    "stylelint": {
      "command": "stylelint",
      "args": [
        "--fix",
        "--stdin",
        "--stdin-filename",
        "%filepath"
      ],
      "rootPatterns": [
        "package.json",
        ".stylelintrc",
        ".stylelintrc.json",
        ".stylelintrc.yaml",
        ".stylelintrc.yml",
        ".stylelintrc.js",
        ".stylelintrc.cjs",
        ".stylelintrc.mjs",
        "stylelint.config.js",
        "stylelint.config.cjs",
        "stylelint.config.mjs",
        ".git"
      ]
    }
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  "cSpell.userWords": [
    "askbot",
    "bable",
    "chax",
    "fabbrica",
    "import",
    "nextjs",
    "openai",
    "qrdspi",
    "ristow",
    "stylelint",
    "upsert",
    "vercel",
    "vite",
    "vitejs",
    "vitest"
  ]
}
