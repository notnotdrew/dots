prefix_rule(pattern=["npm", "run", "test"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "cherry-pick", "--continue"], decision="allow")
prefix_rule(pattern=["git", "checkout", "--ours"], decision="allow")
prefix_rule(pattern=["git", "cherry-pick", "--skip"], decision="allow")
prefix_rule(pattern=["npx", "vitest", "run"], decision="allow")
prefix_rule(pattern=["bundle", "exec", "rspec"], decision="allow")
prefix_rule(pattern=["bundle", "exec", "rails", "db:migrate"], decision="allow")
